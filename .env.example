# ── CPR Sales Tracker — Environment Variables ────────────────────────────────
# Copy this file to .env for local development.
# On Railway: set these under Project → Variables (NOT in a file).

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# Set to "production" on Railway — enables secure HTTPS-only cookies
NODE_ENV=production

# SQLite database path (Railway persistent volume mount point)
# On Railway add a Volume at /data and set this to /data/cpr_sales.db
DB_PATH=/data/cpr_sales.db

# Port (Railway sets this automatically — do not override on Railway)
# PORT=3000
